<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dom.project.mapper.EmployeeFirstDormUseMapper">

    <resultMap id="FirstUseMap" type="com.dom.project.entity.EmployeeFirstDormUse">
        <id column="employee_id" property="employeeId"/>
        <result column="first_use_date" property="firstUseDate"/>
        <result column="created_at" property="createdAt" typeHandler="com.dom.project.config.PostgreSqlLocalDateTimeTypeHandler"/>
        <result column="updated_at" property="updatedAt" typeHandler="com.dom.project.config.PostgreSqlLocalDateTimeTypeHandler"/>
    </resultMap>

    <select id="findByEmployeeId" resultMap="FirstUseMap">
        SELECT employee_id, first_use_date, created_at, updated_at
        FROM employee_first_dorm_use WHERE employee_id = #{employeeId}
    </select>

    <insert id="insert" parameterType="com.dom.project.entity.EmployeeFirstDormUse">
        INSERT INTO employee_first_dorm_use (employee_id, first_use_date, created_at, updated_at)
        VALUES (#{employeeId}, #{firstUseDate}, #{createdAt}, #{updatedAt})
    </insert>
</mapper>
